# Aether is bring-your-own-key by default.
# Keys are stored in the browser (localStorage) via Settings — no server env required.
#
# Optional: pre-seed a default key for local dev only (never commit real keys).
# The Settings UI still takes priority when the user saves a key there.

# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional default model id (OpenRouter format)
# NEXT_PUBLIC_DEFAULT_MODEL=anthropic/claude-sonnet-4
